ANTHROPIC_API_KEY=

# Alpaca: PAPER keys by default. Live requires ALPACA_LIVE=true AND a fresh review.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_LIVE=false
ALPACA_MANUAL_APPROVAL=true

# Risk limits (server-enforced, not UI-enforced).
RISK_MAX_POSITION_PCT=0.10
RISK_DAILY_LOSS_LIMIT_PCT=0.03
RISK_MAX_ORDERS_PER_DAY=20
RISK_PER_TRADE_PCT=0.02
RISK_STOP_LOSS_PCT=0.05
RISK_TAKE_PROFIT_PCT=0.10

# CORS
CORS_ORIGINS=http://localhost:3000

# LLM
DEEP_THINK_LLM=claude-opus-4-7
QUICK_THINK_LLM=claude-sonnet-4-6
MAX_DEBATE_ROUNDS=1
